{
  "name": "visual-join-builder-",
  "displayName": "Visual Join Builder ",
  "description": "Visually join DataFrames and generate Pandas/SQL code.",
  "icon": "media/icon.png",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:visual-join-builder.open",
    "onCommand:visual-join-builder.openFromCell",
    "onLanguage:python",
    "onNotebook:jupyter-notebook"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "visual-join-builder.open",
        "title": "✨ Open Visual Join Builder"
      },
      {
        "command": "visual-join-builder.openFromCell",
        "title": "✨ Visual Join"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "postinstall": "cd webview-ui && npm install",
    "prebuild": "cd webview-ui && npm run build",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test:unit": "jest",
    "test": "vscode-test",
    "vsce:package": "npx @vscode/vsce package --no-dependencies",
    "vsce:publish": "npx @vscode/vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.115.0",
    "@vscode/vsce": "^3.7.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.3",
    "jest": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "ts-jest": "^29.4.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
